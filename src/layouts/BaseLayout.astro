---
// BaseLayout — every page wraps in this. Drives the <head>: per-page <title>,
// description, canonical, OG/Twitter cards, JSON-LD, fonts. Also includes
// global CSS + the dark-mode initialiser so theme switching doesn't flash.
import "../styles/global.css";

export interface Props {
  /** Page title — shown in the browser tab + as og:title. Don't append site name; we do that here. */
  title: string;
  /** Short page description for SEO + og:description + twitter:description. ~150-160 chars max. */
  description: string;
  /** Path-relative canonical, e.g. "/jaya". Optional — defaults to current request URL. */
  canonicalPath?: string;
  /** Optional path to an OG image (relative to /). Defaults to /og/default.png — generated by the OG endpoint. */
  ogImage?: string;
  /** Page type for OG. Articles get "article"; everything else "website". */
  ogType?: "website" | "article";
  /** For article pages: ISO date the essay was published. */
  publishedTime?: string;
  /** Optional structured-data block injected into <head> as JSON-LD. */
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  canonicalPath,
  ogImage = "/og/default.svg",
  ogType = "website",
  publishedTime,
  jsonLd,
} = Astro.props;

const SITE = "Shubz Sharma";
const SITE_URL = "https://shubzsharma.com";
const fullTitle = title === SITE ? title : `${title} — ${SITE}`;
const canonicalUrl = canonicalPath
  ? new URL(canonicalPath, SITE_URL).href
  : new URL(Astro.url.pathname, SITE_URL).href;
const ogImageUrl = new URL(ogImage, SITE_URL).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    {/* SS monogram favicon — PNG for Safari (no SVG favicon support pre-v14),
        SVG for Chrome/Firefox/Edge. apple-touch-icon for iOS home screen. */}
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    {/* Open Graph */}
    <meta property="og:site_name" content={SITE} />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${title} — Shubz Sharma`} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}

    {/* Twitter / X card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={`${title} — Shubz Sharma`} />

    {/* Fonts — preconnect + the same family stack the old single-file site used */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT@0,9..144,300..700,0..100;1,9..144,300..700,0..100&family=Source+Serif+4:ital,opsz,wght@0,8..60,300..700;1,8..60,300..600&family=IBM+Plex+Sans:ital,wght@0,300..700;1,400..600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    {/* Inline pre-paint script so dark mode doesn't flash */}
    <script is:inline>
      (function () {
        try {
          // Default to dark; only switch to light if the user explicitly chose it.
          var saved = localStorage.getItem("theme");
          if (saved !== "light") document.documentElement.dataset.theme = "dark";
        } catch (e) {
          document.documentElement.dataset.theme = "dark";
        }
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
