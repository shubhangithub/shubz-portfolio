---
import BaseLayout from "../layouts/BaseLayout.astro";
import { POSTS } from "../data/posts";

// Show the 4 most-recent essays as soft fallbacks instead of a dead end.
const recent = POSTS.slice(0, 4);
---

<BaseLayout
  title="Not found"
  description="The page you were looking for isn't here. Try one of the recent essays below."
  canonicalPath="/404/"
>
  <main style="max-width: 64ch; margin: 6rem auto 8rem; padding: 0 1.6rem; font-family: var(--f-body);">
    <p class="caps mono" style="color: #1F3DBF; letter-spacing: 0.12em; font-size: 11px;">404 · NOT FOUND</p>
    <h1 class="display" style="font-size: clamp(1.9rem, 7vw, 4.6rem); margin: 0.4rem 0 0; font-weight: 360; line-height: 0.98; letter-spacing: -0.02em; color: #0F1320;">
      That page doesn't exist <em style="color: #1F3DBF;">here</em>.
    </h1>
    <p style="margin-top: 1.4rem; font-size: 1.06rem; line-height: 1.7; color: #6E7488;">
      Either I moved it, or you typed it from memory and memory failed. Try one of these instead:
    </p>

    <div style="margin-top: 2rem; border-top: 1px solid #D5D6DC;">
      {recent.map((post, i) => (
        <a
          href={`/${post.slug}/`}
          class="v4-stack-row"
          style="display: grid; grid-template-columns: 36px 1fr 56px; gap: 1rem; align-items: baseline; padding: 1rem 0; border-bottom: 1px solid #D5D6DC; color: #0F1320; text-decoration: none;"
        >
          <span class="mono" style="color: #6E7488; font-size: 11px;">{String(i + 1).padStart(2, "0")}</span>
          <div>
            <span class="link-underline" style="font-family: var(--f-body); font-size: 1rem;">{post.title}</span>
            <div style="font-size: 0.85rem; color: #6E7488; margin-top: 3px; font-style: italic; line-height: 1.5; max-width: 50ch;">{post.dek}</div>
          </div>
          <span class="mono" style="color: #6E7488; font-size: 11px; text-align: right;">{post.minutes}m</span>
        </a>
      ))}
    </div>

    <p style="margin-top: 2.4rem; font-size: 0.95rem; color: #6E7488;">
      Or head <a href="/" class="link-underline" style="color: #1F3DBF;">home</a>.
    </p>
  </main>
</BaseLayout>
