---
// Home — placeholder while the full migration ports the chrome + diagrams.
// Real hero (portrait + §01 kicker + h1 + lede + compact LV) lands when the
// chrome components are migrated.
import BaseLayout from "../layouts/BaseLayout.astro";
import { POSTS } from "../data/posts";
---

<BaseLayout
  title="Shubz Sharma"
  description="Founding engineer at Orion. Read maths and CS at Oxford. Writes about geospatial ML, biology, optimisation, and the small obsessions in between."
  canonicalPath="/"
  ogType="website"
>
  <main style="max-width: 64ch; margin: 4rem auto; padding: 0 1.6rem; font-family: var(--f-body);">
    <p class="caps mono" style="color: var(--accent, #1F3DBF); letter-spacing: 0.12em; font-size: 11px;">§01 Home · the front door</p>
    <h1 class="display" style="font-size: clamp(1.9rem, 7vw, 4.6rem); margin: 0; font-weight: 360; line-height: 0.98; letter-spacing: -0.02em;">
      Shubz Sharma
    </h1>
    <p style="margin-top: 1.2rem; font-style: italic; color: #6E7488;">
      Astro migration in progress — chrome and diagrams are still being ported. The old single-file site is in <code>index.html</code>; this is the new src/.
    </p>

    <h2 style="margin-top: 3rem;">Essays</h2>
    <ul style="list-style: none; padding: 0;">
      {POSTS.map((post) => (
        <li style="padding: 0.8rem 0; border-bottom: 1px solid #D5D6DC;">
          <a href={`/${post.slug}/`} style="color: #0F1320;">
            <strong>{post.title}</strong> · <span style="color: #6E7488;">{post.dek}</span>
          </a>
        </li>
      ))}
    </ul>
  </main>
</BaseLayout>
