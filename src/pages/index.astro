---
import BaseLayout from "../layouts/BaseLayout.astro";
import AppShell from "../components/pages/AppShell.tsx";
import {
  SITE_DESCRIPTION,
  SITE_HOME_TITLE,
  SITE_NAME,
  SITE_URL,
} from "../data/site";

// JSON-LD: a @graph with Person (Shubhangi) + WebSite. Lets Google connect
// the site to a real entity for Knowledge Graph + sameAs verification.
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${SITE_URL}/#person`,
      name: "Shubhangi Sharma",
      url: SITE_URL,
      jobTitle: "Founding Engineer",
      worksFor: { "@type": "Organization", name: "Torus" },
      alumniOf: [
        { "@type": "CollegeOrUniversity", name: "University of Oxford" },
        { "@type": "CollegeOrUniversity", name: "FLAME University" },
      ],
      image: `${SITE_URL}/contact-portrait.jpg`,
      sameAs: [
        "https://www.linkedin.com/in/shubhangi-s-sharma/",
        "https://github.com/shubhangithub",
        "https://fable.co/fabler/shubz-sharma-375148102003",
        "https://www.strava.com/athletes/155447309",
      ],
    },
    {
      "@type": "WebSite",
      "@id": `${SITE_URL}/#website`,
      url: SITE_URL,
      name: SITE_NAME,
      inLanguage: "en-GB",
      author: { "@id": `${SITE_URL}/#person` },
      publisher: { "@id": `${SITE_URL}/#person` },
    },
  ],
};
---

<BaseLayout
  title={SITE_HOME_TITLE}
  description={SITE_DESCRIPTION}
  canonicalPath="/"
  ogType="website"
  jsonLd={jsonLd}
>
  <AppShell page="home" client:load />
</BaseLayout>
