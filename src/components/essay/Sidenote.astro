---
// Numbered sidenote. Renders inline like a footnote marker [n], with the
// note body itself shown in the right margin on desktop and inline-collapsed
// on mobile (matches the legacy site's sidenote pattern).
//
// Usage in MDX:
//   Some sentence.<Sidenote n={1}>The clarifying aside.</Sidenote>
export interface Props {
  n: number;
}
const { n } = Astro.props;
---

<span class="sidenote-number" style="color: var(--accent, #1F3DBF);">{n}</span>
<span class="sidenote">
  <strong style="color: var(--accent, #1F3DBF);">{n}.</strong>
  <slot />
</span>
