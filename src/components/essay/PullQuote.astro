---
// Pull quote for essay bodies. Uses CSS vars from global.css so it adapts
// to dark mode automatically (no palette prop needed in MDX).
export interface Props {
  color?: string; // optional accent override
}
const { color = "var(--accent, #1F3DBF)" } = Astro.props;
---

<blockquote
  class="pull-quote"
  style={`margin: 3rem -2rem; padding: 1rem 2rem; border-left: 2px solid ${color}; font-family: var(--f-display); font-size: 1.95rem; line-height: 1.2; font-style: italic; font-variation-settings: "opsz" 144, "SOFT" 100, "wght" 320; color: inherit; text-wrap: balance;`}
>
  <slot />
</blockquote>
